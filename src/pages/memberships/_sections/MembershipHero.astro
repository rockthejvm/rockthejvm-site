---
import MyPicture from "@/components/MyPicture.astro";
import MembershipImage from "@/images/logos/personal.png";
import MembershipHeroPricingCard from "@/pages/memberships/_components/MembershipHeroPricingCard";

interface HeroCopy {
  bullets: string[];
  cardSupportText: string;
  description: string;
  coursesLabel: string;
  hoursLabel: string;
  lessonsLabel: string;
  monthlyCtaLabel: string;
  monthlyFallbackLabel: string;
  monthlySupportText: string;
  pricingSeparatorLabel: string;
  savingsLabel: string;
  thumbnailAlt: string;
  yearlyCtaLabel: string;
  yearlyFallbackLabel: string;
  yearlySupportText: string;
}

interface Props {
  courseCount: number;
  currency?: string;
  hero: HeroCopy;
  monthlyPriceInCents?: number;
  monthlyPricingPlanId?: number;
  totalHours: number;
  totalLessons: number;
  yearlyPricingPlanId?: number;
  yearlyPriceInCents?: number;
}

const {
  courseCount,
  currency,
  hero,
  monthlyPriceInCents,
  monthlyPricingPlanId,
  totalHours,
  totalLessons,
  yearlyPricingPlanId,
  yearlyPriceInCents,
} = Astro.props;
---

<header id="membership-hero" class="relative isolate overflow-hidden">
  <div
    class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,_rgba(217,119,6,0.18),_transparent_40%),radial-gradient(circle_at_80%_20%,_rgba(56,189,248,0.18),_transparent_28%),linear-gradient(180deg,_rgba(15,23,42,0.95)_0%,_rgba(15,23,42,0.82)_55%,_rgba(15,23,42,0.96)_100%)] [[data-theme=light]_&]:bg-[radial-gradient(circle_at_top_left,_rgba(245,158,11,0.20),_transparent_38%),radial-gradient(circle_at_80%_20%,_rgba(14,165,233,0.16),_transparent_30%),linear-gradient(180deg,_rgba(255,255,255,0.95)_0%,_rgba(248,250,252,0.95)_100%)]"
  >
  </div>
  <img
    src={MembershipImage.src}
    alt=""
    aria-hidden="true"
    class="parallax-bg pointer-events-none absolute left-[55%] top-[-10%] hidden h-[130%] w-[45%] object-contain opacity-20 blur-3xl lg:block [[data-theme=light]_&]:opacity-15"
    loading="eager"
    decoding="async"
  />
  <div class="absolute inset-0 bg-bkg/20"></div>

  <div
    class="relative mx-auto max-w-7xl px-6 py-16 sm:py-20 lg:grid lg:grid-cols-2 lg:items-start lg:gap-x-12 lg:px-8 lg:py-24"
  >
    <div>
      <h1
        class="max-w-4xl text-4xl font-bold tracking-tight text-content sm:text-5xl lg:text-6xl"
      >
        <slot name="headline" />
      </h1>

      <p class="mt-5 max-w-3xl text-lg leading-8 text-content-1">
        {hero.description}
      </p>

      <dl class="mt-8 flex flex-wrap gap-x-8 gap-y-3">
        <div class="flex items-center gap-x-2">
          <dt>
            <svg
              class="h-5 w-5 text-accent-1"
              viewBox="0 0 20 20"
              fill="currentColor"
              aria-hidden="true"
            >
              <path
                d="M5.127 3.142 1.5 4.25v12.384l3.627-1.084 5.246 1.571 5.5-1.744V3.012L12.373 4.75l-5.246-1.608zM5.25 5.613v9.525l-.75.224V5.836l.75-.223zm4.25.5 1.5.46v9.525l-1.5-.45V6.113zm-2.75-.343 1.25.384v9.524l-1.25-.374V5.77zm7 .066v9.525l-.75.238V5.836l.75.223z"
              ></path>
            </svg>
            <span class="sr-only">{hero.coursesLabel}</span>
          </dt>
          <dd class="text-sm font-medium text-content-1">
            {courseCount}+ {hero.coursesLabel}
          </dd>
        </div>
        <div class="flex items-center gap-x-2">
          <dt>
            <svg
              class="h-5 w-5 text-accent-1"
              viewBox="0 0 20 20"
              fill="currentColor"
              aria-hidden="true"
            >
              <path
                fill-rule="evenodd"
                d="M10 18a8 8 0 100-16 8 8 0 000 16zm.75-13a.75.75 0 00-1.5 0v5c0 .414.336.75.75.75h4a.75.75 0 000-1.5h-3.25V5z"
                clip-rule="evenodd"></path>
            </svg>
            <span class="sr-only">{hero.hoursLabel}</span>
          </dt>
          <dd class="text-sm font-medium text-content-1">
            {totalHours}+ {hero.hoursLabel}
          </dd>
        </div>
        <div class="flex items-center gap-x-2">
          <dt>
            <svg
              class="h-5 w-5 text-accent-1"
              viewBox="0 0 20 20"
              fill="currentColor"
              aria-hidden="true"
            >
              <path
                d="M10.75 16.82A7.462 7.462 0 0115 15.5c.71 0 1.396.098 2.046.282A.75.75 0 0018 15.06v-11a.75.75 0 00-.546-.721A9.006 9.006 0 0015 3a8.963 8.963 0 00-4.25 1.065V16.82zM9.25 4.065A8.963 8.963 0 005 3c-.85 0-1.673.118-2.454.339A.75.75 0 002 4.06v11a.75.75 0 00.954.721A7.506 7.506 0 015 15.5c1.579 0 3.042.487 4.25 1.32V4.065z"
              ></path>
            </svg>
            <span class="sr-only">{hero.lessonsLabel}</span>
          </dt>
          <dd class="text-sm font-medium text-content-1">
            {totalLessons}+ {hero.lessonsLabel}
          </dd>
        </div>
      </dl>

      <ul class="mt-8 space-y-3 text-sm leading-6 text-content-1 sm:text-base">
        {
          hero.bullets.map((bullet) => (
            <li class="flex gap-x-3">
              <span class="mt-2 h-2.5 w-2.5 shrink-0 rounded-full bg-accent-1" />
              <span>{bullet}</span>
            </li>
          ))
        }
      </ul>
    </div>

    <div class="mt-10 lg:mt-0">
      <div
        class="transition-all duration-500 ease-out [transform:perspective(1200px)_rotateY(-8deg)_rotateX(3deg)] [will-change:transform] hover:[transform:perspective(1200px)_rotateY(0deg)_rotateX(0deg)_scale(1.04)]"
      >
        <MyPicture
          src={MembershipImage}
          alt={hero.thumbnailAlt}
          class="w-full rounded-2xl object-cover"
          quality="mid"
          widths={[400, 640, 800, 1280]}
          sizes="(min-width: 1024px) 640px, 100vw"
        />
      </div>

      <div class="mt-6 sm:mx-auto sm:w-3/5">
        <MembershipHeroPricingCard
          {currency}
          {hero}
          {monthlyPriceInCents}
          {monthlyPricingPlanId}
          {yearlyPriceInCents}
          {yearlyPricingPlanId}
          client:load
        />
      </div>
    </div>
  </div>
</header>
