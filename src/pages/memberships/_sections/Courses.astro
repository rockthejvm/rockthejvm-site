---
import CourseCardVertical from "@/components/CourseCardVertical.astro";
import XMark from "@/components/icons/XMark.astro";
import Section from "@/components/Section.astro";
import compareByNaturalOrder from "@/utils/compareByNaturalOrder";
import { Image } from "astro:assets";
import { getCollection } from "astro:content";

const categories = await getCollection(
  "courseCategories",
  ({ data }) => data.id !== "bundle",
);
const courses = await getCollection(
  "courses",
  ({ data }) => data.category.id !== "bundle" && !data.archived,
);

const coursesByCategory = categories
  .map((cat) => ({
    category: cat,
    courses: [...courses]
      .filter((c) => c.data.category.id === cat.id)
      .sort((a, b) => compareByNaturalOrder(a.data.title, b.data.title)),
  }))
  .filter(({ courses }) => courses.length > 0);
---

<Section id="courses" color="bg-secondary" title="Courses Included">
  <!-- Category grid -->
  <ul
    class="mx-auto grid max-w-3xl list-none grid-cols-2 gap-4 p-0 sm:grid-cols-3 sm:gap-5 lg:grid-cols-4 lg:gap-6"
  >
    {
      coursesByCategory.map(({ category: cat }, i) => (
        <li class="cat-wrapper" style={`--stagger: ${i};`}>
          <button
            type="button"
            class="cat-card group block h-full w-full text-left"
            style={`--accent: ${cat.data.color};`}
            aria-expanded="false"
            aria-controls={`cat-panel-${cat.id}`}
            data-cat-id={cat.id}
          >
            <div class="cat-inner h-full rounded-2xl px-5 pb-6 pt-8 text-center">
              <figure class="cat-icon mx-auto mb-4 flex size-[72px] items-center justify-center rounded-full bg-white">
                <Image
                  src={cat.data.logo}
                  alt={cat.data.name}
                  class="h-11 w-11 object-contain"
                  widths={[44, 88]}
                  sizes="44px"
                />
              </figure>
              <h4 class="text-sm font-semibold text-content-1 transition-colors group-hover:text-link-hover">
                {cat.data.name}
              </h4>
            </div>
          </button>
        </li>
      ))
    }
  </ul>

  <!-- Accordion panels -->
  {
    coursesByCategory.map(({ category: cat, courses: catCourses }) => (
      <div
        id={`cat-panel-${cat.id}`}
        class="cat-panel hidden"
        data-cat-id={cat.id}
      >
        <div class="mx-auto mt-8 max-w-5xl">
          <div class="mb-6 flex items-center justify-between">
            <h3 class="text-2xl font-bold text-content">
              {cat.data.name} Courses
            </h3>
            <button
              type="button"
              class="cat-close rounded-md p-1.5 text-content-2 transition-colors hover:text-content"
              data-cat-id={cat.id}
              aria-label={`Close ${cat.data.name} courses`}
            >
              <XMark />
            </button>
          </div>
          <ul class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
            {catCourses.map((course) => (
              <li class="col-span-1 flex justify-center divide-y rounded-lg bg-none">
                <CourseCardVertical {course} />
              </li>
            ))}
          </ul>
        </div>
      </div>
    ))
  }
</Section>

<style>
  /* ── Staggered entrance ── */
  .cat-wrapper {
    opacity: 0;
    transform: translateY(28px);
    transition:
      opacity 0.5s ease calc(var(--stagger, 0) * 75ms),
      transform 0.5s ease calc(var(--stagger, 0) * 75ms);
  }
  .cat-wrapper.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* ── Card shell ── */
  .cat-card {
    perspective: 900px;
  }

  /* ── Per-theme card background ── */
  :root[data-theme="light"] .cat-inner {
    --cat-card-bg: color-mix(in srgb, var(--accent) 7%, white);
    --cat-card-bg-hover: color-mix(in srgb, var(--accent) 13%, white);
  }
  :root[data-theme="dark"] .cat-inner {
    --cat-card-bg: color-mix(in srgb, var(--accent) 14%, hsl(210deg 40% 16%));
    --cat-card-bg-hover: color-mix(
      in srgb,
      var(--accent) 22%,
      hsl(210deg 40% 20%)
    );
  }

  .cat-inner {
    --cat-card-bg: color-mix(in srgb, var(--accent) 7%, white);
    --cat-card-bg-hover: color-mix(in srgb, var(--accent) 13%, white);
    border: 1px solid color-mix(in srgb, var(--accent) 40%, transparent);
    background: var(--cat-card-bg);
    transition:
      border-color 0.3s ease,
      box-shadow 0.3s ease,
      background 0.3s ease;
  }
  .cat-card:hover .cat-inner,
  .cat-card:focus-visible .cat-inner {
    border-color: color-mix(in srgb, var(--accent) 75%, transparent);
    background: var(--cat-card-bg-hover);
    box-shadow:
      0 0 0 1px color-mix(in srgb, var(--accent) 18%, transparent),
      0 8px 32px -8px color-mix(in srgb, var(--accent) 40%, transparent),
      0 24px 64px -16px color-mix(in srgb, var(--accent) 28%, transparent);
  }

  /* ── Active state for selected category ── */
  .cat-card[aria-expanded="true"] .cat-inner {
    border-color: color-mix(in srgb, var(--accent) 75%, transparent);
    background: var(--cat-card-bg-hover);
    box-shadow:
      0 0 0 2px color-mix(in srgb, var(--accent) 50%, transparent),
      0 8px 32px -8px color-mix(in srgb, var(--accent) 40%, transparent);
  }

  /* ── Logo circle ── */
  .cat-icon {
    box-shadow:
      0 2px 8px rgba(0, 0, 0, 0.12),
      0 0 0 1px color-mix(in srgb, var(--accent) 20%, transparent);
    transition:
      box-shadow 0.3s ease,
      transform 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  .cat-card:hover .cat-icon {
    box-shadow:
      0 4px 20px color-mix(in srgb, var(--accent) 45%, transparent),
      0 0 0 2px color-mix(in srgb, var(--accent) 60%, transparent);
    transform: scale(1.12) translateY(-3px);
  }

  /* ── Panel slide-in ── */
  .cat-panel {
    overflow: hidden;
    max-height: 0;
    opacity: 0;
    transition:
      max-height 0.4s ease,
      opacity 0.3s ease;
  }
  .cat-panel.is-open {
    display: block;
    opacity: 1;
    max-height: 2000px;
  }
</style>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("is-visible");
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.08 },
  );
  document.querySelectorAll<HTMLElement>(".cat-wrapper").forEach((el) => {
    observer.observe(el);
  });

  let openCatId: string | null = null;

  function toggleCategory(catId: string) {
    const wasOpen = openCatId === catId;

    if (openCatId) {
      const prevBtn = document.querySelector<HTMLButtonElement>(
        `.cat-card[data-cat-id="${openCatId}"]`,
      );
      const prevPanel = document.getElementById(`cat-panel-${openCatId}`);
      prevBtn?.setAttribute("aria-expanded", "false");
      prevPanel?.classList.remove("is-open");
      setTimeout(() => {
        if (!prevPanel?.classList.contains("is-open")) {
          prevPanel?.classList.add("hidden");
        }
      }, 400);
    }

    if (!wasOpen) {
      const btn = document.querySelector<HTMLButtonElement>(
        `.cat-card[data-cat-id="${catId}"]`,
      );
      const panel = document.getElementById(`cat-panel-${catId}`);
      btn?.setAttribute("aria-expanded", "true");
      panel?.classList.remove("hidden");
      panel?.offsetHeight;
      panel?.classList.add("is-open");
      openCatId = catId;

      setTimeout(() => {
        panel?.scrollIntoView({ behavior: "smooth", block: "nearest" });
      }, 100);
    } else {
      openCatId = null;
    }
  }

  document
    .querySelectorAll<HTMLButtonElement>(".cat-card[data-cat-id]")
    .forEach((btn) => {
      btn.addEventListener("click", () => {
        const catId = btn.dataset.catId!;
        toggleCategory(catId);
      });
    });

  document
    .querySelectorAll<HTMLButtonElement>(".cat-close[data-cat-id]")
    .forEach((btn) => {
      btn.addEventListener("click", () => {
        const catId = btn.dataset.catId!;
        toggleCategory(catId);
      });
    });
</script>
