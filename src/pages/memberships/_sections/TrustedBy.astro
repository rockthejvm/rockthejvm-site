---
/**
 * "Trusted By" logo marquee.
 *
 * ADDING LOGOS
 * ============
 * 1. Place a monochrome SVG named `<id>.svg` in src/icons/companies/
 *    Recommended viewBox: 0 0 158 48 · single fill color (no hard-coded colours)
 *    The SVG should use `currentColor` or inherit fill so CSS can control colour.
 * 2. Add the company to src/data/companies.yaml with the matching id.
 * 3. Add the id to the `logos` array below.
 *
 * CURRENT LOGOS (src/icons/companies/<id>.svg):
 *   adobe · apple · carvana · datto · google · hapag-lloyd
 *   hm-revenue-and-customs · intuit · iov42 · microsoft · orange
 *   swiss-re · ververica
 */

import { Icon } from "astro-icon/components";

const logos = [
  { id: "adobe", name: "Adobe" },
  { id: "apple", name: "Apple" },
  { id: "google", name: "Google" },
  { id: "microsoft", name: "Microsoft" },
  { id: "intuit", name: "Intuit" },
  { id: "orange", name: "Orange" },
  { id: "swiss-re", name: "Swiss Re" },
  { id: "ververica", name: "Ververica" },
  { id: "hapag-lloyd", name: "Hapag-Lloyd" },
  { id: "datto", name: "Datto" },
  { id: "carvana", name: "Carvana" },
  { id: "iov42", name: "iov42" },
  { id: "hm-revenue-and-customs", name: "HM Revenue & Customs" },
];
---

<section class="overflow-hidden pb-10">
  <p
    class="pb-8 mb-6 text-center text-xs font-semibold uppercase tracking-widest text-content-1/40"
  >
    Trusted by
  </p>

  <div class="relative">
    <!-- Fade masks at edges -->
    <div
      class="pointer-events-none absolute inset-y-0 left-0 z-10 w-16 bg-gradient-to-r from-bkg to-transparent"
    >
    </div>
    <div
      class="pointer-events-none absolute inset-y-0 right-0 z-10 w-16 bg-gradient-to-l from-bkg to-transparent"
    >
    </div>

    <div class="marquee-track flex w-max items-center gap-x-14">
      <!-- Duplicate the list for seamless looping -->
      {
        [...logos, ...logos].map(({ id, name }) => (
          <div class="flex pb-10 w-44 shrink-0 items-center justify-center opacity-40 grayscale transition-opacity duration-200 hover:opacity-70">
            <Icon
              name={`companies/${id}`}
              title={name}
              width={112}
              height={36}
              class="max-h-16 w-full fill-content object-contain"
            />
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  @keyframes marquee {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(-50%);
    }
  }
  .marquee-track {
    animation: marquee 35s linear infinite;
  }
  .marquee-track:hover {
    animation-play-state: paused;
  }
</style>
