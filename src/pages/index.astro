---
import BackgroundGradient from "@/components/BackgroundGradient.astro";
import Contact from "@/components/Contact.astro";
import TrustedBy from "@/components/TrustedBy.astro";
import site from "@/data/site.json";
import Logo from "@/images/logos/rock-the-jvm.svg";
import BaseLayout from "@/layouts/BaseLayout/BaseLayout.astro";
import Courses from "./_components/Courses.astro";
import Founder from "./_components/Founder.astro";
import Hero from "./_components/Hero.astro";
import HomeBackgroundBlobs from "./_components/HomeBackgroundBlobs.astro";
import HomeFAQ from "./_components/HomeFAQ.astro";
import HomeTeams from "./_components/HomeTeams.astro";
import HomeTestimonials from "./_components/HomeTestimonials.astro";
import LatestContent from "./_components/LatestContent.astro";
import Membership from "./_components/Membership.astro";
import PlatformComparison from "./_components/PlatformComparison.astro";
import ValueProp from "./_components/ValueProp.astro";
import WhoIsItFor from "./_components/WhoIsItFor.astro";
---

<BaseLayout
  description={site.description}
  image={{ src: Logo.src, alt: site.logo.alt }}
  isHomePage={true}
  title="Home"
>
  <BackgroundGradient />

  <div class="relative overflow-hidden text-white">
    <HomeBackgroundBlobs />
    <Hero />
    <TrustedBy />
    <!-- Main content sections — narrow container -->
    <div class="container z-10 mx-auto px-4 sm:px-6 lg:px-4">
      <ValueProp />
      <Courses />
      <Membership />
      <HomeTeams />
      <HomeTestimonials />
      <WhoIsItFor />
      <PlatformComparison />
      <LatestContent />
      <Founder />
      <HomeFAQ />
      <Contact />
    </div>
  </div>
</BaseLayout>
