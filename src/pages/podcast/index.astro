---
import BackgroundGradient from "@/components/BackgroundGradient.astro";
import Podcasts from "@/components/Podcasts.astro";
import BaseLayout from "@/layouts/BaseLayout/BaseLayout.astro";
import { fetchPodcastFeed } from "@/utils/fetchPodcastFeed";

const episodes = await fetchPodcastFeed();
---

<BaseLayout
  title="Podcast"
  description="Rock the Code — a podcast about interesting programming topics for the curious software engineer."
>
  <header class="pt-8 md:pt-16">
    <h1 class="mx-6 text-center text-content-1 lg:mx-8">
      Rock the Code Podcast
    </h1>
  </header>
  <BackgroundGradient />
  <Podcasts {episodes} />
</BaseLayout>
