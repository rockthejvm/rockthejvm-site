---
type Indicator = "yes" | "no" | string;

interface Row {
  feature: string;
  rockthejvm: Indicator;
  frontendmasters: Indicator;
  udemy: Indicator;
  coursera: Indicator;
  oreilly: Indicator;
}

const rows: Row[] = [
  {
    feature: "Deep content on niche tech\n(e.g. Scala, effect systems)",
    rockthejvm: "yes",
    frontendmasters: "no",
    udemy: "no",
    coursera: "limited",
    oreilly: "limited",
  },
  {
    feature: "Code-first teaching",
    rockthejvm: "yes",
    frontendmasters: "yes",
    udemy: "some",
    coursera: "some",
    oreilly: "no",
  },
  {
    feature: "Non-trivial projects",
    rockthejvm: "yes",
    frontendmasters: "yes",
    udemy: "rarely",
    coursera: "some (capstones)",
    oreilly: "no",
  },
  {
    feature: "Senior-level content",
    rockthejvm: "yes",
    frontendmasters: "yes",
    udemy: "rarely",
    coursera: "some",
    oreilly: "yes",
  },
  {
    feature: "All-access membership",
    rockthejvm: "yes",
    frontendmasters: "yes",
    udemy: "limited",
    coursera: "no",
    oreilly: "yes",
  },
  {
    feature: "Private community",
    rockthejvm: "yes",
    frontendmasters: "no",
    udemy: "no",
    coursera: "limited (forum)",
    oreilly: "no",
  },
];

const competitors = [
  { key: "frontendmasters", label: "Frontend Masters" },
  { key: "udemy", label: "Udemy" },
  { key: "coursera", label: "Coursera" },
  { key: "oreilly", label: "O'Reilly" },
] as const;

type CompetitorKey = (typeof competitors)[number]["key"];
---

<section class="mb-12 md:mb-20">
  <div class="mx-auto mb-12 max-w-3xl text-center">
    <p class="mb-3 text-sm font-semibold uppercase tracking-widest text-accent-1">
      How we stack up
    </p>
    <h2 class="mb-4 text-3xl font-extrabold tracking-tight text-content sm:text-4xl">
      Rock the JVM vs. the alternatives
    </h2>
    <p class="text-lg leading-8 text-content-1">
      There are a lot of places to learn online. Here's how Rock the JVM
      compares for the engineer who wants to level up seriously.
    </p>
  </div>

  <div class="comparison-table overflow-x-auto">
    <table class="w-full text-sm">
      <thead>
        <tr class="border-b border-content/10">
          <!-- Sticky: Feature column -->
          <th class="sticky left-0 z-20 w-[180px] min-w-[180px] max-w-[180px] bg-bkg py-4 pl-6 pr-4 text-left font-medium text-content-1 sm:w-[220px] sm:min-w-[220px] sm:max-w-[220px]">
            Feature
          </th>
          <!-- Sticky: Rock the JVM column -->
          <th class="sticky left-[180px] z-20 min-w-[120px] border-t-2 border-cta bg-cta/10 px-4 py-4 text-center font-semibold text-accent-1 sm:left-[220px]">
            Rock the JVM
          </th>
          <!-- Scrollable: competitors -->
          {
            competitors.map(({ label }) => (
              <th class="px-4 py-4 text-center font-semibold text-content-1 whitespace-nowrap">
                {label}
              </th>
            ))
          }
        </tr>
      </thead>
      <tbody>
        {
          rows.map((row, i) => (
            <tr
              class:list={[
                "border-b border-content/10 last:border-0",
                i % 2 === 1 ? "bg-white/[0.02] [[data-theme=light]_&]:bg-black/5" : "",
              ]}
            >
              <!-- Sticky: Feature -->
              <td class="sticky left-0 z-10 w-[180px] min-w-[180px] max-w-[180px] bg-bkg py-4 pl-6 pr-4 leading-6 text-content whitespace-pre-line sm:w-[220px] sm:min-w-[220px] sm:max-w-[220px]">
                {row.feature}
              </td>
              <!-- Sticky: Rock the JVM value -->
              <td class="sticky left-[180px] z-10 min-w-[120px] bg-cta/10 px-4 py-4 text-center sm:left-[220px]">
                <span class="inline-flex items-center justify-center text-green-300 [[data-theme=light]_&]:text-green-700">
                  <svg viewBox="0 0 20 20" fill="currentColor" class="h-5 w-5" aria-label="Yes">
                    <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" />
                  </svg>
                </span>
              </td>
              <!-- Scrollable: competitor values -->
              {competitors.map(({ key }) => {
                const val = row[key as CompetitorKey];
                return (
                  <td class="px-4 py-4 text-center">
                    {val === "yes" && (
                      <span class="inline-flex items-center justify-center text-green-300 [[data-theme=light]_&]:text-green-700">
                        <svg viewBox="0 0 20 20" fill="currentColor" class="h-5 w-5" aria-label="Yes">
                          <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" />
                          </svg>
                      </span>
                    )}
                    {val === "no" && (
                      <span class="inline-flex items-center justify-center text-red-300 [[data-theme=light]_&]:text-red-700">
                        <svg viewBox="0 0 20 20" fill="currentColor" class="h-5 w-5" aria-label="No">
                          <path d="M6.28 5.22a.75.75 0 00-1.06 1.06L8.94 10l-3.72 3.72a.75.75 0 101.06 1.06L10 11.06l3.72 3.72a.75.75 0 101.06-1.06L11.06 10l3.72-3.72a.75.75 0 00-1.06-1.06L10 8.94 6.28 5.22z" />
                        </svg>
                      </span>
                    )}
                    {val !== "yes" && val !== "no" && (
                      <span class="text-yellow-300 text-xs font-medium [[data-theme=light]_&]:text-amber-700">{val}</span>
                    )}
                  </td>
                );
              })}
            </tr>
          ))
        }
      </tbody>
    </table>
  </div>

</section>
