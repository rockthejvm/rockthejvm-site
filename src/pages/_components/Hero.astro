---
import site from "@/data/site.json";
import HeroAnnotation from "./HeroAnnotation.astro";
import HeroCodeCardWrapper from "./HeroCodeCardWrapper.astro";
---

<header class="pb-16 pt-12 md:pt-20">
  <!-- Latest course pill -->
  <div class="mb-8 hidden sm:flex sm:justify-center">
    <div
      class="relative rounded-full px-3 py-1 text-sm leading-6 text-content-1 ring-1 ring-content-2/10 hover:ring-content-2/20"
    >
      <HeroAnnotation />
    </div>
  </div>

  <!-- 2-column grid: copy on left, code card on right -->
  <div
    class="mx-auto grid max-w-7xl grid-cols-1 items-center gap-x-12 gap-y-12 px-4 sm:px-6 lg:grid-cols-2 lg:px-8"
  >
    <!-- Left: headline + value prop + stats + CTAs -->
    <div class="flex flex-col">
      <h1
        class="text-4xl font-extrabold tracking-tight text-content sm:text-5xl lg:text-6xl"
      >
        Become a senior engineer
      </h1>
      <p class="mt-3 text-lg leading-8 text-content-1 sm:mt-6">
        We teach powerful, niche technologies used at scale, and solid mental models on type safety, concurrency and system design — the kind of judgment that separates senior engineers from everyone else.
      </p>
      <p class="mt-4 hidden text-lg leading-8 text-content-1 sm:block">
        Skip AI chats and shallow answers, and follow a smooth learning curve where code is king.
      </p>

      <!-- Stats -->
      <div class="mt-3 flex flex-wrap gap-x-6 gap-y-2 text-sm text-content-1 sm:mt-6">
        <span class="flex items-center gap-x-1.5">
          <span class="inline-block h-1.5 w-1.5 rounded-full bg-accent-1"
          ></span>
          30+ courses
        </span>
        <span class="flex items-center gap-x-1.5">
          <span class="inline-block h-1.5 w-1.5 rounded-full bg-accent-1"
          ></span>
          250+ hours of content
        </span>
        <span class="flex items-center gap-x-1.5">
          <span class="inline-block h-1.5 w-1.5 rounded-full bg-accent-1"
          ></span>
          Since {site.founded}
        </span>
      </div>

      <!-- CTAs -->
      <div
        class="mt-4 flex flex-col gap-y-3 sm:mt-8 sm:flex-row sm:flex-wrap sm:gap-x-4"
      >
        <a
          href="/memberships"
          class="rounded-md bg-cta px-5 py-3 text-center text-sm font-semibold text-ctatext shadow-sm transition-colors hover:bg-accent-1 hover:text-white hover:no-underline focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent-1"
        >
          Explore the Membership
        </a>
        <a
          href="/courses"
          class="rounded-md px-5 py-3 text-center text-sm font-semibold text-content ring-1 ring-inset ring-content/30 transition-colors hover:ring-content/60 hover:no-underline"
        >
          Browse Courses &rarr;
        </a>
      </div>
    </div>

    <!-- Right: code card -->
    <div class="w-full">
      <HeroCodeCardWrapper />
    </div>
  </div>
</header>
