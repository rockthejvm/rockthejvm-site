---
import site from "@/data/site.json";
import { YouTube } from "astro-embed";
import HeroAnnotation from "./HeroAnnotation.astro";

const videoId = "Cg8gASzqqOs";
---

<header class="pb-16 pt-12 md:pt-20">
  <!-- Latest course pill -->
  <div class="mb-8 hidden sm:flex sm:justify-center">
    <div
      class="relative rounded-full px-3 py-1 text-sm leading-6 text-content-1 ring-1 ring-content-2/10 hover:ring-content-2/20"
    >
      <HeroAnnotation />
    </div>
  </div>

  <!-- 2-column grid: copy on left, video on right -->
  <div
    class="mx-auto grid max-w-7xl grid-cols-1 items-center gap-x-12 gap-y-12 px-4 sm:px-6 lg:grid-cols-2 lg:px-8"
  >
    <!-- Left: headline + value prop + stats + CTAs -->
    <div class="flex flex-col">
      <h1
        class="text-4xl font-extrabold tracking-tight text-content sm:text-5xl lg:text-6xl"
      >
        Become a senior engineer
      </h1>
      <p class="mt-6 text-lg leading-8 text-content-1">
        We give software engineers hands-on training on the powerful, niche programming topics used by the very best.
        <br />
        <br />
        Skip AI chats and outdated tutorials. Save yourself the time and frustration and follow a smooth learning curve where code is king.
      </p>

      <!-- Stats -->
      <div class="mt-6 flex flex-wrap gap-x-6 gap-y-2 text-sm text-content-1">
        <span class="flex items-center gap-x-1.5">
          <span class="inline-block h-1.5 w-1.5 rounded-full bg-accent-1"
          ></span>
          {site.stats.studentsLabel} students
        </span>
        <span class="flex items-center gap-x-1.5">
          <span class="inline-block h-1.5 w-1.5 rounded-full bg-accent-1"
          ></span>
          30+ courses
        </span>
        <span class="flex items-center gap-x-1.5">
          <span class="inline-block h-1.5 w-1.5 rounded-full bg-accent-1"
          ></span>
          Since {site.founded}
        </span>
      </div>

      <!-- CTAs -->
      <div
        class="mt-8 flex flex-col gap-y-3 sm:flex-row sm:flex-wrap sm:gap-x-4"
      >
        <a
          href="/memberships"
          class="rounded-md bg-cta px-5 py-3 text-center text-sm font-semibold text-ctatext shadow-sm transition-colors hover:bg-accent-1 hover:text-white focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent-1"
        >
          Explore the Membership
        </a>
        <a
          href="/courses"
          class="rounded-md px-5 py-3 text-center text-sm font-semibold text-content ring-1 ring-inset ring-content/30 transition-colors hover:ring-content/60"
        >
          Browse Courses &rarr;
        </a>
      </div>
    </div>

    <!-- Right: video embed -->
    <div class="w-full overflow-hidden rounded-2xl shadow-2xl ring-1 ring-content/10">
      <YouTube
        id={videoId}
        title="Rock the JVM — Become the Senior Engineer You&rsquo;re Meant to Be"
        posterQuality="high"
        class="aspect-video w-full"
      />
    </div>
  </div>
</header>
