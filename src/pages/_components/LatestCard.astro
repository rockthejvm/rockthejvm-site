---
interface Props {
  link: string;
  contents: {
    url: string;
    title: string;
  }[];
  type: string;
}

const { contents, link, type } = Astro.props;
---

<div class="w-full rounded-3xl lg:col-span-1">
  <div
    class="card-shadow card-shadow-color w-full overflow-hidden rounded-3xl bg-secondary ring-1 ring-content/10"
  >
    <slot name="thumbnail" />
    <div class="mx-auto mb-4 w-full">
      <div class="mx-auto w-full">
        <a href={link} class="no-underline hover:no-underline">
          <h3
            class="my-4 text-center text-3xl font-semibold text-content hover:text-link-hover sm:text-4xl"
          >
            Latest {type}
          </h3>
        </a>
        <div class="w-full py-4 sm:py-4">
          <ul class="m-0 list-none p-0">
            {
              contents.map(async ({ title, url }) => (
                <li class="group relative mx-auto flex w-full items-center justify-center px-8 hover:bg-content/5">
                  <a
                    href={url}
                    class="article-home-link text-md mx-auto my-1 flex w-full flex-col items-center justify-center py-2 leading-5 text-content no-underline hover:text-link-hover hover:no-underline"
                    title={title}
                  >
                    <p class="w-full overflow-hidden text-ellipsis text-nowrap text-center">
                      {title}
                    </p>
                  </a>
                </li>
              ))
            }
          </ul>
        </div>
      </div>
    </div>
  </div>
</div>
