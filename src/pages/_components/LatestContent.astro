---
import LatestArticles from "./LatestArticles.astro";
import LatestPodcast from "./LatestPodcast.astro";
import LatestVideos from "./LatestVideos.astro";

const size = 5;
---

<section class="mb-8 md:mb-16">
  <h2 class="mb-12 text-center font-bold text-content">Free Resources</h2>
  <div
    class="mx-4 flex max-w-7xl flex-col gap-y-10 sm:mx-8 md:mx-12 lg:mx-auto lg:grid lg:grid-cols-3 lg:gap-x-10"
  >
    <LatestArticles {size} />
    <LatestVideos {size} />
    <LatestPodcast />
  </div>
  <div class="mt-10 flex flex-wrap justify-center gap-4">
    <a
      href="/articles/1"
      class="rounded-md bg-cta px-5 py-3 text-sm font-semibold text-ctatext shadow-sm transition-colors hover:bg-accent-1 hover:text-white"
    >
      All Articles &rarr;
    </a>
    <a
      href="/podcast"
      class="rounded-md px-5 py-3 text-sm font-semibold text-content ring-1 ring-inset ring-content/30 transition-colors hover:ring-content/60"
    >
      Listen to the Podcast &rarr;
    </a>
  </div>
</section>
