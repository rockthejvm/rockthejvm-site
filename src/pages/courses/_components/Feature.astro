---
import MyPicture from "@/components/MyPicture.astro";
import Prose from "@/components/Prose.astro";
import type { ImageMetadata } from "astro";

interface Props {
  image: ImageMetadata;
  imagePosition: "left" | "right";
  imageRounded?: boolean;
  imageClassName?: string;
}

const {
  image,
  imagePosition,
  imageRounded = false,
  imageClassName = "w-full",
} = Astro.props;
---

<div class="mx-auto grid max-w-5xl grid-cols-1 items-center gap-8 py-8 sm:grid-cols-2 sm:gap-10">
  <div class={imagePosition === "right" ? "order-2 sm:order-2" : "order-2 sm:order-1"}>
    <MyPicture
      class={`${imageRounded ? "rounded-full mx-auto w-3/4" : "rounded-xl w-full"} ${imageClassName}`}
      src={image}
      alt=""
      quality="mid"
    />
  </div>
  <div class={imagePosition === "right" ? "order-1 sm:order-1" : "order-1 sm:order-2"}>
    <Prose>
      <slot />
    </Prose>
  </div>
</div>
