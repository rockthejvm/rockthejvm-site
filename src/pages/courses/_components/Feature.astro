---
import MyPicture from "@/components/MyPicture.astro";
import MyVideo from "@/components/MyVideo.astro";
import Prose from "@/components/Prose.astro";
import type { ImageMetadata } from "astro";

interface Props {
  image: ImageMetadata;
  imagePosition: "left" | "right";
  imageRounded?: boolean;
  imageClassName?: string;
  /** Optional video sources. When provided, renders an autoplaying video using `image` as the poster. */
  video?: { mp4: string; webm: string };
}

const {
  image,
  imagePosition,
  imageRounded = false,
  imageClassName = "w-full",
  video,
} = Astro.props;

const mediaClass = `${imageRounded ? "rounded-full mx-auto w-3/4" : "rounded-xl w-full"} ${imageClassName}`;
---

<div
  class="mx-auto grid max-w-5xl grid-cols-1 items-center gap-8 py-8 sm:grid-cols-2 sm:gap-10"
>
  <div class={imagePosition === "right" ? "order-2" : "order-2 sm:order-1"}>
    {
      video ? (
        <MyVideo
          class={mediaClass}
          poster={image}
          mp4={video.mp4}
          webm={video.webm}
        />
      ) : (
        <MyPicture
          class={mediaClass}
          src={image}
          alt=""
          quality="mid"
          widths={[400, 512, 1024]}
          sizes="(min-width: 640px) 512px, 100vw"
        />
      )
    }
  </div>
  <div class={imagePosition === "right" ? "order-1" : "order-1 sm:order-2"}>
    <Prose>
      <slot />
    </Prose>
  </div>
</div>
