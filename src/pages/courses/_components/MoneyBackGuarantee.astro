---
import MyPicture from "@/components/MyPicture.astro";
import MoneyBackGuaranteeImage from "@/images/misc/money-back-guarantee.svg";
---

<div class="mx-auto my-12 max-w-4xl">
  <div
    class="card-shadow card-shadow-color flex flex-col items-center gap-6 rounded-2xl bg-secondary/60 p-8 ring-1 ring-accent-2/30 sm:flex-row sm:gap-10 sm:p-10"
  >
    <MyPicture
      class="w-32 shrink-0 sm:w-40"
      width={160}
      src={MoneyBackGuaranteeImage}
      quality="mid"
      alt="money back guarantee"
    />
    <div>
      <h3 class="text-lg font-bold text-content">100% Money Back Guarantee</h3>
      <p class="mt-3 text-sm leading-7 text-content-1">
        If you're not happy with this course, I want you to have your money
        back. <a href="/contact" class="text-accent-1 hover:text-link-hover"
          >Contact me</a
        >
        with a copy of your welcome email and I will refund you.
      </p>
      <p class="mt-2 text-sm leading-7 text-content-1">
        Less than 0.05% of students have ever asked for a refund — and every
        payment was returned in under 72 hours.
      </p>
    </div>
  </div>
</div>
