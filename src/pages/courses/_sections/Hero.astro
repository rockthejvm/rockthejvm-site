---
import MyPicture from "@/components/MyPicture.astro";
import NewsletterSection from "@/components/NewsletterSection.astro";
import PurchaseLink from "@/components/PurchaseLink";
import centsToPrice from "@/utils/centsToPrice";
import type { CollectionEntry } from "astro:content";

type CourseFrontmatter = CollectionEntry<"courses">["data"];

interface Props {
  benefits: CourseFrontmatter["benefits"];
  bundledCoursesCount: number;
  bundleHours?: number;
  bundleLessons?: number;
  currency?: string;
  totalLessons?: number;
  description: CourseFrontmatter["description"];
  difficulty?: CollectionEntry<"difficulties">;
  heroImage: CourseFrontmatter["heroImage"];
  inRoadmap: boolean;
  isFree: boolean;
  isBundle: boolean;
  isPreview: boolean;
  instructors: CollectionEntry<"authors">[];
  monthlyMembershipPriceInCents?: number;
  monthlyMembershipPricingPlanId?: number;
  priceInCents?: number;
  pricingPlanId: CourseFrontmatter["pricingPlanId"];
  showMembership?: boolean;
  title: CourseFrontmatter["title"];
  videoId?: string;
}

const {
  benefits,
  bundledCoursesCount,
  bundleHours,
  bundleLessons,
  currency,
  totalLessons,
  description,
  difficulty,
  heroImage,
  inRoadmap,
  isFree,
  isBundle,
  isPreview,
  instructors,
  monthlyMembershipPriceInCents,
  monthlyMembershipPricingPlanId,
  priceInCents,
  pricingPlanId,
  showMembership = true,
  title,
  videoId,
} = Astro.props;

const formattedPrice =
  priceInCents !== undefined && currency !== undefined
    ? centsToPrice(priceInCents, currency)
    : null;

const formattedMembershipPrice =
  monthlyMembershipPriceInCents !== undefined && currency !== undefined
    ? centsToPrice(monthlyMembershipPriceInCents, currency)
    : null;

const difficultyColorClass: Record<string, string> = {
  beginner: "bg-blue-500/20 text-blue-400 ring-1 ring-inset ring-blue-400/40 [[data-theme=light]_&]:text-blue-700 [[data-theme=light]_&]:ring-blue-700/40",
  intermediate: "bg-amber-500/20 text-amber-400 ring-1 ring-inset ring-amber-400/40 [[data-theme=light]_&]:text-amber-700 [[data-theme=light]_&]:ring-amber-700/40",
  advanced: "bg-red-500/20 text-red-400 ring-1 ring-inset ring-red-400/40 [[data-theme=light]_&]:text-red-700 [[data-theme=light]_&]:ring-red-700/40",
};

const instructorNames = instructors.map((i) => i.data.name).join(" & ");
---

<header id="course-hero" class="relative overflow-hidden">
  <!-- Blurred, dimmed background version of the hero image -->
  <MyPicture
    alt=""
    src={heroImage}
    class="absolute inset-0 size-full scale-110 object-cover brightness-[0.2] hero-bg-image"
    loading="eager"
    quality="low"
  />
  <!-- Theme-aware overlay -->
  <div class="absolute inset-0 bg-bkg/80"></div>

  <!-- Main content grid -->
  <div
    class="relative mx-auto max-w-7xl px-6 py-16 sm:py-20 lg:grid lg:grid-cols-2 lg:items-start lg:gap-x-12 lg:px-8 lg:py-24"
  >
    <!-- Left column: course info + CTAs -->
    <div class="order-2 mt-10 lg:order-1 lg:mt-0">
      <!-- Badges row -->
      <div class="mb-5 flex flex-wrap items-center gap-2">
        {
          difficulty && (
            <span
              class={`${difficultyColorClass[difficulty.data.id] ?? "bg-accent-2/20 text-accent-2 ring-1 ring-inset ring-accent-2/40"} rounded-full px-3 py-1 text-sm font-semibold`}
            >
              {difficulty.data.name}
            </span>
          )
        }
        {
          isBundle && (
            <span class="rounded-full bg-accent-1/20 px-3 py-1 text-sm font-semibold text-accent-1 ring-1 ring-inset ring-accent-1/40">
              Bundle
            </span>
          )
        }
        {
          isFree && (
            <span class="rounded-full bg-green-500/20 px-3 py-1 text-sm font-semibold text-green-400 ring-1 ring-inset ring-green-400/40">
              Free
            </span>
          )
        }
        {
          isPreview && (
            <span class="rounded-full bg-yellow-500/20 px-3 py-1 text-sm font-semibold text-yellow-400 ring-1 ring-inset ring-yellow-400/40">
              Coming Soon
            </span>
          )
        }
      </div>

      <!-- Title -->
      <h1 class="text-4xl font-bold tracking-tight text-content sm:text-5xl">
        {title}
      </h1>

      <!-- Description -->
      <p class="mt-5 text-lg leading-8 text-content-1">
        {description}
      </p>

      <!-- Roadmap link -->
      {inRoadmap && (
        <button
          id="open-roadmap-modal"
          class="mt-2 text-sm text-accent-2 hover:text-accent-1 hover:underline focus:outline-none"
        >
          Check roadmap &rarr;
        </button>
      )}

      <!-- Stats row -->
      <dl class="mt-8 flex flex-wrap gap-x-8 gap-y-3">
        {
          benefits && (
            <>
              <div class="flex items-center gap-x-2">
                <dt>
                  <svg
                    class="h-5 w-5 text-accent-2"
                    viewBox="0 0 20 20"
                    fill="currentColor"
                    aria-hidden="true"
                  >
                    <path
                      fill-rule="evenodd"
                      d="M10 18a8 8 0 100-16 8 8 0 000 16zm.75-13a.75.75 0 00-1.5 0v5c0 .414.336.75.75.75h4a.75.75 0 000-1.5h-3.25V5z"
                      clip-rule="evenodd"
                    />
                  </svg>
                  <span class="sr-only">Duration</span>
                </dt>
                <dd class="text-sm font-medium text-content-1">
                  {benefits.hours}h of 4K content
                </dd>
              </div>
              {totalLessons !== undefined && totalLessons > 0 && (
                <div class="flex items-center gap-x-2">
                  <dt>
                    <svg
                      class="h-5 w-5 text-accent-2"
                      viewBox="0 0 20 20"
                      fill="currentColor"
                      aria-hidden="true"
                    >
                      <path d="M10.75 16.82A7.462 7.462 0 0115 15.5c.71 0 1.396.098 2.046.282A.75.75 0 0018 15.06v-11a.75.75 0 00-.546-.721A9.006 9.006 0 0015 3a8.963 8.963 0 00-4.25 1.065V16.82zM9.25 4.065A8.963 8.963 0 005 3c-.85 0-1.673.118-2.454.339A.75.75 0 002 4.06v11a.75.75 0 00.954.721A7.506 7.506 0 015 15.5c1.579 0 3.042.487 4.25 1.32V4.065z" />
                    </svg>
                    <span class="sr-only">Lessons</span>
                  </dt>
                  <dd class="text-sm font-medium text-content-1">
                    {totalLessons} lessons
                  </dd>
                </div>
              )}
            </>
          )
        }
        {
          isBundle && (
            <>
              <div class="flex items-center gap-x-2">
                <dt>
                  <svg
                    class="h-5 w-5 text-accent-2"
                    viewBox="0 0 20 20"
                    fill="currentColor"
                    aria-hidden="true"
                  >
                    <path d="M5.127 3.142 1.5 4.25v12.384l3.627-1.084 5.246 1.571 5.5-1.744V3.012L12.373 4.75l-5.246-1.608zM5.25 5.613v9.525l-.75.224V5.836l.75-.223zm4.25.5 1.5.46v9.525l-1.5-.45V6.113zm-2.75-.343 1.25.384v9.524l-1.25-.374V5.77zm7 .066v9.525l-.75.238V5.836l.75.223z" />
                  </svg>
                  <span class="sr-only">Courses included</span>
                </dt>
                <dd class="text-sm font-medium text-content-1">
                  {bundledCoursesCount} courses included
                </dd>
              </div>
              {bundleHours !== undefined && bundleHours > 0 && (
                <div class="flex items-center gap-x-2">
                  <dt>
                    <svg
                      class="h-5 w-5 text-accent-2"
                      viewBox="0 0 20 20"
                      fill="currentColor"
                      aria-hidden="true"
                    >
                      <path
                        fill-rule="evenodd"
                        d="M10 18a8 8 0 100-16 8 8 0 000 16zm.75-13a.75.75 0 00-1.5 0v5c0 .414.336.75.75.75h4a.75.75 0 000-1.5h-3.25V5z"
                        clip-rule="evenodd"
                      />
                    </svg>
                    <span class="sr-only">Total duration</span>
                  </dt>
                  <dd class="text-sm font-medium text-content-1">
                    {bundleHours}h of 4K content
                  </dd>
                </div>
              )}
              {bundleLessons !== undefined && bundleLessons > 0 && (
                <div class="flex items-center gap-x-2">
                  <dt>
                    <svg
                      class="h-5 w-5 text-accent-2"
                      viewBox="0 0 20 20"
                      fill="currentColor"
                      aria-hidden="true"
                    >
                      <path d="M10.75 16.82A7.462 7.462 0 0115 15.5c.71 0 1.396.098 2.046.282A.75.75 0 0018 15.06v-11a.75.75 0 00-.546-.721A9.006 9.006 0 0015 3a8.963 8.963 0 00-4.25 1.065V16.82zM9.25 4.065A8.963 8.963 0 005 3c-.85 0-1.673.118-2.454.339A.75.75 0 002 4.06v11a.75.75 0 00.954.721A7.506 7.506 0 015 15.5c1.579 0 3.042.487 4.25 1.32V4.065z" />
                    </svg>
                    <span class="sr-only">Total lessons</span>
                  </dt>
                  <dd class="text-sm font-medium text-content-1">
                    {bundleLessons} lessons
                  </dd>
                </div>
              )}
            </>
          )
        }
      </dl>

      <!-- Instructors -->
      <div class="mt-8 flex items-center gap-x-3">
        <div class="flex -space-x-2">
          {
            instructors.slice(0, 3).map((instructor) => (
              <MyPicture
                src={instructor.data.photo}
                alt={instructor.data.name}
                class="h-10 w-10 rounded-full object-cover ring-2 ring-content/30"
                quality="low"
                width={40}
              />
            ))
          }
        </div>
        <p class="text-sm text-content-1">
          By <span class="font-semibold text-content">{instructorNames}</span>
        </p>
      </div>

      {isPreview && (
        <div class="mt-10">
          <NewsletterSection
            stacked={true}
            {isPreview}
            title="Get notified when this course launches!"
          />
        </div>
      )}
    </div>

    <!-- Right column: hero image + price/CTA -->
    <div class="order-1 lg:order-2">
      <div class="relative overflow-hidden rounded-2xl shadow-2xl ring-1 ring-white/10">
        <MyPicture
          alt={title}
          src={heroImage}
          class="w-full object-cover"
          loading="eager"
          quality="mid"
          searchImage={true}
        />
        {videoId && (
          <button
            id="open-video-modal"
            data-video-id={videoId}
            aria-label="Play course preview"
            class="absolute inset-0 flex items-center justify-center bg-black/30 transition-colors hover:bg-black/50 focus:outline-none focus-visible:ring-2 focus-visible:ring-white"
          >
            <span class="flex h-16 w-16 items-center justify-center rounded-full bg-white/90 shadow-xl transition-transform hover:scale-110">
              <svg class="ml-1 h-7 w-7 text-gray-900" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path d="M6.3 2.84A1.5 1.5 0 004 4.11v11.78a1.5 1.5 0 002.3 1.27l9.344-5.891a1.5 1.5 0 000-2.538L6.3 2.84z" />
              </svg>
            </span>
          </button>
        )}
      </div>

      {!isPreview && (
        <div class="mt-6 rounded-2xl bg-content/5 px-6 py-5 ring-1 ring-content/10 backdrop-blur-sm">
          <div class="flex flex-col gap-3">
            {showMembership && formattedMembershipPrice && monthlyMembershipPricingPlanId && (
              <>
                <p class="text-center text-lg font-medium text-content-1">
                  Join <span class="font-semibold text-content">100,000+ students</span> enrolled in Rock the JVM courses
                </p>
                <PurchaseLink
                  pricingPlanId={monthlyMembershipPricingPlanId}
                  className="block rounded-md bg-cta px-6 py-3 text-center text-base font-semibold text-ctatext shadow-sm hover:bg-accent-1 hover:text-gray-50 hover:no-underline focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-cta"
                  client:load
                >
                  {isFree ? "Access for Free" : `Access for ${formattedMembershipPrice}/mo`}
                </PurchaseLink>
                <div class="flex items-center gap-3">
                  <div class="h-px flex-1 bg-content/15"></div>
                  <span class="text-xs text-content-1">or</span>
                  <div class="h-px flex-1 bg-content/15"></div>
                </div>
              </>
            )}
            <PurchaseLink
              {pricingPlanId}
              className={`block rounded-md px-4 py-2 text-center text-sm font-medium shadow-sm hover:no-underline focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 ${
                showMembership && formattedMembershipPrice
                  ? "bg-content/10 text-content-1 ring-1 ring-inset ring-content/20 hover:bg-content/20 focus-visible:outline-content/50"
                  : "bg-cta text-ctatext hover:bg-accent-1 hover:text-gray-50 focus-visible:outline-cta"
              }`}
              client:load
            >
              {isFree ? "Enroll for Free" : `Buy ${isBundle ? "bundle" : "course"}${formattedPrice ? ` — ${formattedPrice}` : ""}`}
            </PurchaseLink>
          </div>
          <p class="mt-3 text-sm text-center text-content-1">
            Money-back guarantee &middot; Unlimited access &middot; Free updates
          </p>
        </div>
      )}
    </div>
  </div>

  </div>
</header>

<!-- Video modal (outside <header> so fixed positioning isn't clipped by overflow-hidden) -->
{videoId && (
  <div
    id="video-modal"
    class="hidden"
    role="dialog"
    aria-modal="true"
    aria-label="Course preview video"
  >
    <div
      id="video-modal-backdrop"
      class="fixed inset-0 z-50 bg-black/80 opacity-0 transition-opacity"
      aria-hidden="true"
    ></div>
    <div class="fixed inset-0 z-50 flex items-center justify-center p-4">
      <div
        id="video-modal-panel"
        class="relative w-full max-w-6xl scale-95 opacity-0 transition-all duration-200"
      >
        <button
          id="close-video-modal"
          class="absolute right-0 -top-10 text-white/70 hover:text-white focus:outline-none"
          aria-label="Close video"
        >
          <svg class="h-8 w-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
        <div class="aspect-w-16 aspect-h-9 w-full overflow-hidden rounded-xl shadow-2xl">
          <div id="video-modal-player" class="absolute inset-0"></div>
        </div>
      </div>
    </div>
  </div>
)}

<!-- Roadmap modal (outside <header> so fixed positioning isn't clipped by overflow-hidden) -->
<div
  id="roadmap-modal"
  class="hidden"
  aria-labelledby="modal-title"
  role="dialog"
  aria-modal="true"
>
  <div
    id="modal-roadmap-backdrop"
    class="fixed inset-0 z-50 bg-gray-500/75 opacity-0 transition-opacity"
    aria-hidden="true"
  >
  </div>
  <div class="fixed inset-0 z-50 flex items-center justify-center p-6 sm:p-10">
    <div
      class="relative h-3/4 w-full max-w-5xl translate-y-4 overflow-hidden rounded-xl bg-secondary opacity-0 shadow-xl transition-all sm:scale-95"
      id="modal-roadmap-panel"
    >
      <h2 class="my-4 w-full text-center text-content-1">Course Roadmap</h2>
      <div class="h-[calc(100%-3.5rem)] w-full overflow-hidden">
        <slot name="roadmap" />
      </div>
    </div>
  </div>
</div>

<style>
  /* Lighten the blurred background on the light theme */
  :global([data-theme="light"]) .hero-bg-image {
    filter: brightness(0.45);
  }
</style>

<script>
  // ── Roadmap modal ──────────────────────────────────────────────────
  const openModalButton = document.getElementById("open-roadmap-modal");
  const modal = document.getElementById("roadmap-modal");
  const modalBackdrop = document.getElementById("modal-roadmap-backdrop");
  const modalPanel = document.getElementById("modal-roadmap-panel");

  if (openModalButton && modal && modalBackdrop && modalPanel) {
    function showModal() {
      modal!.classList.remove("hidden");
      modalBackdrop!.classList.add("opacity-100");
      modalBackdrop!.classList.remove("opacity-0");
      modalPanel!.classList.add("opacity-100", "translate-y-0", "sm:scale-100");
      modalPanel!.classList.remove(
        "opacity-0",
        "translate-y-4",
        "sm:translate-y-0",
        "sm:scale-95",
      );
      const searchInput = document.querySelector(
        '#search input[type="text"]',
      ) as HTMLInputElement | null;
      searchInput?.focus();
    }

    function hideModal() {
      modal!.classList.add("hidden");
      modalBackdrop!.classList.add("opacity-0");
      modalBackdrop!.classList.remove("opacity-100");
      modalPanel!.classList.add(
        "opacity-0",
        "translate-y-4",
        "sm:translate-y-0",
        "sm:scale-95",
      );
      modalPanel!.classList.remove(
        "opacity-100",
        "translate-y-0",
        "sm:scale-100",
      );
    }

    openModalButton.addEventListener("click", showModal);

    document.addEventListener("keydown", (event) => {
      const isMac = navigator.platform.toUpperCase().includes("MAC");
      const ctrlOrCmdKey = isMac ? event.metaKey : event.ctrlKey;
      if (ctrlOrCmdKey && event.key === "k") {
        event.preventDefault();
        showModal();
      }
      if (event.key === "Escape") hideModal();
    });

    modal.addEventListener("click", ({ target }) => {
      if (!modalPanel!.contains(target as Node | null)) hideModal();
    });
  }

  // ── Video modal ────────────────────────────────────────────────────
  const openVideoButton = document.getElementById("open-video-modal");
  const videoModal = document.getElementById("video-modal");
  const videoBackdrop = document.getElementById("video-modal-backdrop");
  const videoPanel = document.getElementById("video-modal-panel");
  const closeVideoButton = document.getElementById("close-video-modal");
  const videoPlayer = document.getElementById("video-modal-player");

  if (openVideoButton && videoModal && videoBackdrop && videoPanel && videoPlayer) {
    // Read videoId from data attribute set at render time
    const videoId = openVideoButton.dataset.videoId;

    function showVideoModal() {
      videoModal!.classList.remove("hidden");
      videoBackdrop!.classList.add("opacity-100");
      videoBackdrop!.classList.remove("opacity-0");
      videoPanel!.classList.add("opacity-100", "scale-100");
      videoPanel!.classList.remove("opacity-0", "scale-95");
      // Inject YouTube iframe on first open
      if (videoPlayer!.childElementCount === 0 && videoId) {
        videoPlayer!.innerHTML = `<iframe
          src="https://www.youtube-nocookie.com/embed/${videoId}?autoplay=1&rel=0"
          title="Course preview"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
          style="position:absolute;inset:0;width:100%;height:100%;border:0"
        ></iframe>`;
      }
    }

    function hideVideoModal() {
      videoModal!.classList.add("hidden");
      videoBackdrop!.classList.add("opacity-0");
      videoBackdrop!.classList.remove("opacity-100");
      videoPanel!.classList.add("opacity-0", "scale-95");
      videoPanel!.classList.remove("opacity-100", "scale-100");
      // Stop video by clearing src
      videoPlayer!.innerHTML = "";
    }

    openVideoButton.addEventListener("click", showVideoModal);
    closeVideoButton?.addEventListener("click", hideVideoModal);

    videoModal.addEventListener("click", ({ target }) => {
      if (!videoPanel!.contains(target as Node | null)) hideVideoModal();
    });

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape" && !videoModal!.classList.contains("hidden")) {
        hideVideoModal();
      }
    });
  }
</script>
