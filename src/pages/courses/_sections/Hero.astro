---
import MyPicture from "@/components/MyPicture.astro";
import NewsletterSection from "@/components/NewsletterSection.astro";
import HeroMediaCard from "../_components/HeroMediaCard.astro";
import RoadmapModal from "../_components/RoadmapModal.astro";
import VideoModal from "../_components/VideoModal.astro";
import type { CollectionEntry } from "astro:content";

type CourseFrontmatter = CollectionEntry<"courses">["data"];

interface Props {
  benefits: CourseFrontmatter["benefits"];
  bundledCoursesCount: number;
  bundleHours?: number;
  bundleLessons?: number;
  currency?: string;
  totalLessons?: number;
  description: CourseFrontmatter["description"];
  difficulty?: CollectionEntry<"difficulties">;
  heroImage: CourseFrontmatter["heroImage"];
  heroImageBgSrc: string;
  inRoadmap: boolean;
  isFree: boolean;
  isBundle: boolean;
  isPreview: boolean;
  instructors: CollectionEntry<"authors">[];
  monthlyMembershipPriceInCents?: number;
  monthlyMembershipPricingPlanId?: number;
  priceInCents?: number;
  pricingPlanId: CourseFrontmatter["pricingPlanId"];
  showMembership?: boolean;
  title: CourseFrontmatter["title"];
  videoId?: string;
}

const {
  benefits,
  bundledCoursesCount,
  bundleHours,
  bundleLessons,
  currency,
  totalLessons,
  description,
  difficulty,
  heroImage,
  heroImageBgSrc,
  inRoadmap,
  isFree,
  isBundle,
  isPreview,
  instructors,
  monthlyMembershipPriceInCents,
  monthlyMembershipPricingPlanId,
  priceInCents,
  pricingPlanId,
  showMembership = true,
  title,
  videoId,
} = Astro.props;

const difficultyColorClass: Record<string, string> = {
  beginner: "bg-blue-500/20 text-blue-400 ring-1 ring-inset ring-blue-400/40 [[data-theme=light]_&]:text-blue-700 [[data-theme=light]_&]:ring-blue-700/40",
  intermediate: "bg-amber-500/20 text-amber-400 ring-1 ring-inset ring-amber-400/40 [[data-theme=light]_&]:text-amber-700 [[data-theme=light]_&]:ring-amber-700/40",
  advanced: "bg-red-500/20 text-red-400 ring-1 ring-inset ring-red-400/40 [[data-theme=light]_&]:text-red-700 [[data-theme=light]_&]:ring-red-700/40",
};

const instructorNames = instructors.map((i) => i.data.name).join(" & ");
---

<header id="course-hero" class="relative overflow-hidden">
  <!-- Parallax background image -->
  <img
    src={heroImageBgSrc}
    alt=""
    aria-hidden="true"
    class="parallax-bg pointer-events-none absolute left-0 top-[-15%] h-[130%] w-full object-cover brightness-[0.15] [[data-theme=light]_&]:brightness-[0.35]"
    loading="eager"
    decoding="async"
  />
  <!-- Theme-aware overlay -->
  <div class="absolute inset-0 bg-bkg/20 [[data-theme=light]_&]:bg-bkg/80"></div>

  <!-- Main content grid -->
  <div
    class="relative mx-auto max-w-7xl px-6 py-16 sm:py-20 lg:grid lg:grid-cols-2 lg:items-start lg:gap-x-12 lg:px-8 lg:py-24"
  >
    <!-- Left column: course info + CTAs -->
    <div class="order-2 mt-10 lg:order-1 lg:mt-0">
      <!-- Badges row -->
      <div class="mb-5 flex flex-wrap items-center gap-2">
        {
          difficulty && (
            <span
              class={`${difficultyColorClass[difficulty.data.id] ?? "bg-accent-2/20 text-accent-2 ring-1 ring-inset ring-accent-2/40"} rounded-full px-3 py-1 text-sm font-semibold`}
            >
              {difficulty.data.name}
            </span>
          )
        }
        {
          isBundle && (
            <span class="rounded-full bg-accent-1/20 px-3 py-1 text-sm font-semibold text-accent-1 ring-1 ring-inset ring-accent-1/40">
              Bundle
            </span>
          )
        }
        {
          isFree && (
            <span class="rounded-full bg-green-500/20 px-3 py-1 text-sm font-semibold text-green-400 ring-1 ring-inset ring-green-400/40">
              Free
            </span>
          )
        }
        {
          isPreview && (
            <span class="rounded-full bg-yellow-500/20 px-3 py-1 text-sm font-semibold text-yellow-400 ring-1 ring-inset ring-yellow-400/40">
              Coming Soon
            </span>
          )
        }
      </div>

      <!-- Title -->
      <h1 class="text-4xl font-bold tracking-tight text-content sm:text-5xl">
        {title}
      </h1>

      <!-- Description -->
      <p class="mt-5 text-lg leading-8 text-content-1">
        {description}
      </p>

      <!-- Roadmap link -->
      {inRoadmap && (
        <button
          id="open-roadmap-modal"
          class="mt-2 text-sm text-accent-2 hover:text-accent-1 hover:underline focus:outline-none"
        >
          Check roadmap &rarr;
        </button>
      )}

      <!-- Stats row -->
      <dl class="mt-8 flex flex-wrap gap-x-8 gap-y-3">
        {
          benefits && (
            <>
              <div class="flex items-center gap-x-2">
                <dt>
                  <svg
                    class="h-5 w-5 text-accent-2"
                    viewBox="0 0 20 20"
                    fill="currentColor"
                    aria-hidden="true"
                  >
                    <path
                      fill-rule="evenodd"
                      d="M10 18a8 8 0 100-16 8 8 0 000 16zm.75-13a.75.75 0 00-1.5 0v5c0 .414.336.75.75.75h4a.75.75 0 000-1.5h-3.25V5z"
                      clip-rule="evenodd"
                    />
                  </svg>
                  <span class="sr-only">Duration</span>
                </dt>
                <dd class="text-sm font-medium text-content-1">
                  {benefits.hours}h of 4K content
                </dd>
              </div>
              {totalLessons !== undefined && totalLessons > 0 && (
                <div class="flex items-center gap-x-2">
                  <dt>
                    <svg
                      class="h-5 w-5 text-accent-2"
                      viewBox="0 0 20 20"
                      fill="currentColor"
                      aria-hidden="true"
                    >
                      <path d="M10.75 16.82A7.462 7.462 0 0115 15.5c.71 0 1.396.098 2.046.282A.75.75 0 0018 15.06v-11a.75.75 0 00-.546-.721A9.006 9.006 0 0015 3a8.963 8.963 0 00-4.25 1.065V16.82zM9.25 4.065A8.963 8.963 0 005 3c-.85 0-1.673.118-2.454.339A.75.75 0 002 4.06v11a.75.75 0 00.954.721A7.506 7.506 0 015 15.5c1.579 0 3.042.487 4.25 1.32V4.065z" />
                    </svg>
                    <span class="sr-only">Lessons</span>
                  </dt>
                  <dd class="text-sm font-medium text-content-1">
                    {totalLessons} lessons
                  </dd>
                </div>
              )}
            </>
          )
        }
        {
          isBundle && (
            <>
              <div class="flex items-center gap-x-2">
                <dt>
                  <svg
                    class="h-5 w-5 text-accent-2"
                    viewBox="0 0 20 20"
                    fill="currentColor"
                    aria-hidden="true"
                  >
                    <path d="M5.127 3.142 1.5 4.25v12.384l3.627-1.084 5.246 1.571 5.5-1.744V3.012L12.373 4.75l-5.246-1.608zM5.25 5.613v9.525l-.75.224V5.836l.75-.223zm4.25.5 1.5.46v9.525l-1.5-.45V6.113zm-2.75-.343 1.25.384v9.524l-1.25-.374V5.77zm7 .066v9.525l-.75.238V5.836l.75.223z" />
                  </svg>
                  <span class="sr-only">Courses included</span>
                </dt>
                <dd class="text-sm font-medium text-content-1">
                  {bundledCoursesCount} courses included
                </dd>
              </div>
              {bundleHours !== undefined && bundleHours > 0 && (
                <div class="flex items-center gap-x-2">
                  <dt>
                    <svg
                      class="h-5 w-5 text-accent-2"
                      viewBox="0 0 20 20"
                      fill="currentColor"
                      aria-hidden="true"
                    >
                      <path
                        fill-rule="evenodd"
                        d="M10 18a8 8 0 100-16 8 8 0 000 16zm.75-13a.75.75 0 00-1.5 0v5c0 .414.336.75.75.75h4a.75.75 0 000-1.5h-3.25V5z"
                        clip-rule="evenodd"
                      />
                    </svg>
                    <span class="sr-only">Total duration</span>
                  </dt>
                  <dd class="text-sm font-medium text-content-1">
                    {bundleHours}h of 4K content
                  </dd>
                </div>
              )}
              {bundleLessons !== undefined && bundleLessons > 0 && (
                <div class="flex items-center gap-x-2">
                  <dt>
                    <svg
                      class="h-5 w-5 text-accent-2"
                      viewBox="0 0 20 20"
                      fill="currentColor"
                      aria-hidden="true"
                    >
                      <path d="M10.75 16.82A7.462 7.462 0 0115 15.5c.71 0 1.396.098 2.046.282A.75.75 0 0018 15.06v-11a.75.75 0 00-.546-.721A9.006 9.006 0 0015 3a8.963 8.963 0 00-4.25 1.065V16.82zM9.25 4.065A8.963 8.963 0 005 3c-.85 0-1.673.118-2.454.339A.75.75 0 002 4.06v11a.75.75 0 00.954.721A7.506 7.506 0 015 15.5c1.579 0 3.042.487 4.25 1.32V4.065z" />
                    </svg>
                    <span class="sr-only">Total lessons</span>
                  </dt>
                  <dd class="text-sm font-medium text-content-1">
                    {bundleLessons} lessons
                  </dd>
                </div>
              )}
            </>
          )
        }
      </dl>

      <!-- Instructors -->
      <div class="mt-8 flex items-center gap-x-3">
        <div class="flex -space-x-2">
          {
            instructors.slice(0, 3).map((instructor) => (
              <MyPicture
                src={instructor.data.photo}
                alt={instructor.data.name}
                class="h-10 w-10 rounded-full object-cover ring-2 ring-content/30"
                quality="low"
                width={40}
              />
            ))
          }
        </div>
        <p class="text-sm text-content-1">
          By <span class="font-semibold text-content">{instructorNames}</span>
        </p>
      </div>

      {isPreview && (
        <div class="mt-10">
          <NewsletterSection
            stacked={true}
            {isPreview}
            title="Get notified when this course launches!"
          />
        </div>
      )}
    </div>

    <!-- Right column: hero image + price/CTA -->
    <HeroMediaCard
      {currency}
      {heroImage}
      {isBundle}
      {isFree}
      {isPreview}
      monthlyMembershipPriceInCents={monthlyMembershipPriceInCents}
      monthlyMembershipPricingPlanId={monthlyMembershipPricingPlanId}
      priceInCents={priceInCents}
      {pricingPlanId}
      {showMembership}
      {title}
      {videoId}
    />
  </div>

  </div>
</header>

<!-- Video modal (outside <header> so fixed positioning isn't clipped by overflow-hidden) -->
<VideoModal {videoId} />

<!-- Roadmap modal (outside <header> so fixed positioning isn't clipped by overflow-hidden) -->
<RoadmapModal>
  <slot name="roadmap" />
</RoadmapModal>

<style>
  /* Lighten the blurred background on the light theme */
  :global([data-theme="light"]) .hero-bg-image {
    filter: brightness(0.45);
  }
</style>

<script>
  import "../_scripts/courseHero";
</script>
