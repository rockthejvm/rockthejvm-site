---
import Section from "@/components/Section.astro";
import { getTeachablePricingPlan } from "@/utils/teachable";
import type { CollectionEntry } from "astro:content";
import { getCollection } from "astro:content";
import MoneyBackGuarantee from "../_components/MoneyBackGuarantee.astro";
import PricingPanels from "../_components/PricingPanels";

interface Props {
  benefits: CollectionEntry<"courses">["data"]["benefits"];
  bundledCourses: CollectionEntry<"courses">[];
  courseId: CollectionEntry<"courses">["id"];
  color: CollectionEntry<"courseCategories">["data"]["color"];
  currency: string;
  isCourse: boolean;
  monthlyMembershipPricingPlanId: number;
  monthlyPriceInCents: number;
  priceInCents: number;
  pricingPlanId: CollectionEntry<"courses">["data"]["pricingPlanId"];
  showMembership: boolean;
  title: CollectionEntry<"courses">["data"]["title"];
  yearlyMembershipPricingPlanId: number;
  yearlyPriceInCents: number;
}

const {
    benefits,
    bundledCourses,
    color,
    courseId,
    currency,
    isCourse,
    monthlyMembershipPricingPlanId,
    monthlyPriceInCents,
    priceInCents,
    pricingPlanId,
    showMembership,
    title,
    yearlyMembershipPricingPlanId,
    yearlyPriceInCents,
  } = Astro.props,
  hours = isCourse
    ? benefits!.hours
    : bundledCourses
        .map(({ data: { benefits } }) => benefits?.hours ?? 0)
        .reduce((b, a) => b + a, 0),
  linesOfCode = isCourse
    ? benefits!.linesOfCode
    : bundledCourses
        .map(({ data: { benefits } }) => benefits?.linesOfCode ?? 0)
        .reduce((b, a) => b + a, 0),
  _courses = await getCollection("courses"),
  membershipHours = _courses
    .map(({ data: { benefits } }) => benefits?.hours ?? 0)
    .reduce((b, a) => b + a, 0),
  membershipLinesOfCode = _courses
    .map(({ data: { benefits } }) => benefits?.linesOfCode ?? 0)
    .reduce((b, a) => b + a, 0),
  categories = await getCollection(
    "courseCategories",
    ({ data: { id } }) => id !== "bundle",
  ),
  featuredBundles = _courses.filter((course) =>
    course.data.bundledCourses?.some(({ id }) => id === courseId),
  );

// Bundle panel data: only shown on individual course pages that belong to a bundle
let bundleData:
  | {
      id: string;
      title: string;
      pricingPlanId: number;
      priceInCents: number;
      courseCount: number;
      hours: number;
      linesOfCode: number;
      savingsPercent?: number;
    }
  | undefined = undefined;

if (isCourse && featuredBundles.length > 0) {
  // Fetch all featured bundle prices and pick the cheapest
  const bundlePlans = await Promise.all(
    featuredBundles.map((b) => getTeachablePricingPlan(b.data.pricingPlanId)),
  );
  let cheapestIdx = 0;
  for (let i = 1; i < bundlePlans.length; i++) {
    const curr = bundlePlans[i]?.price ?? Infinity;
    const best = bundlePlans[cheapestIdx]?.price ?? Infinity;
    if (curr < best) cheapestIdx = i;
  }
  const cheapestBundle = featuredBundles[cheapestIdx];
  const cheapestPlan = bundlePlans[cheapestIdx];

  if (cheapestBundle && cheapestPlan) {
    const bundledCourseIds =
      cheapestBundle.data.bundledCourses?.map((ref) => ref.id) ?? [];
    const bundledCourseEntries = _courses.filter((c) =>
      bundledCourseIds.includes(c.id),
    );

    const bundleHours = bundledCourseEntries.reduce(
      (sum, c) => sum + (c.data.benefits?.hours ?? 0),
      0,
    );
    const bundleLoC = bundledCourseEntries.reduce(
      (sum, c) => sum + (c.data.benefits?.linesOfCode ?? 0),
      0,
    );

    // Fetch individual prices to compute bundle savings vs buying separately
    const individualPlans = await Promise.all(
      bundledCourseEntries.map((c) =>
        getTeachablePricingPlan(c.data.pricingPlanId),
      ),
    );
    const sumIndividual = individualPlans
      .filter((p): p is NonNullable<typeof p> => p !== null)
      .reduce((sum, p) => sum + p.price, 0);
    const savingsPercent =
      sumIndividual > 0
        ? Math.round((1 - cheapestPlan.price / sumIndividual) * 100)
        : undefined;

    bundleData = {
      id: cheapestBundle.id,
      title: cheapestBundle.data.title,
      pricingPlanId: cheapestBundle.data.pricingPlanId,
      priceInCents: cheapestPlan.price,
      courseCount: bundledCourseIds.length,
      hours: bundleHours,
      linesOfCode: bundleLoC,
      savingsPercent,
    };
  }
}
---

<Section id="pricing" {color} title="Enroll now!">
  <div class="relative isolate w-full px-2 py-1 sm:px-6 sm:py-2 lg:px-8">
    <div class="mx-auto max-w-2xl text-center lg:max-w-4xl"></div>
    {
      monthlyPriceInCents > 0 ? (
        <PricingPanels
          {categories}
          {currency}
          {hours}
          {linesOfCode}
          {isCourse}
          {membershipHours}
          {membershipLinesOfCode}
          {monthlyMembershipPricingPlanId}
          {yearlyMembershipPricingPlanId}
          {monthlyPriceInCents}
          {yearlyPriceInCents}
          {priceInCents}
          {pricingPlanId}
          {showMembership}
          {title}
          bundle={bundleData}
          client:visible={{ rootMargin: "2160px" }}
        />
      ) : (
        <p>MISSING TEACHABLE_API_KEY</p>
      )
    }
    <MoneyBackGuarantee />
  </div>
</Section>
