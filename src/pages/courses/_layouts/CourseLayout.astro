---
import { getImage } from "astro:assets";
import Profile from "@/components/Profile.astro";
import site from "@/data/site.json";
import BaseLayout from "@/layouts/BaseLayout/BaseLayout.astro";
import type { ReactFlowEdge, ReactFlowNode } from "@/types/ReactFlow";
import { getTeachablePricingPlan } from "@/utils/teachable";
import {
  type CollectionEntry,
  getCollection,
  getEntries,
  getEntry,
} from "astro:content";
import CoursePageNav from "../_components/CoursePageNav.astro";
import Roadmap from "../_components/Roadmap";
import StickyCTA from "../_components/StickyCTA";
import BundledCourses from "../_sections/BundledCourses.astro";
import CourseFAQ from "../_sections/CourseFAQ.astro";
import CourseTestimonials from "../_sections/CourseTestimonials.astro";
import Curriculum from "../_sections/Curriculum.astro";
import Features from "../_sections/Features.astro";
import Goal from "../_sections/Goal.astro";
import Hero from "../_sections/Hero.astro";
import Pricing from "../_sections/Pricing.astro";
import Question from "../_sections/Question.astro";
import Skills from "../_sections/Skills.astro";
import TechStack from "../_sections/TechStack.astro";

interface Response {
  price: number;
}

const course = await getEntry(
    "courses",
    Astro.params.id as CollectionEntry<"courses">["id"],
  )!,
  _frontmatter = course.data,
  [bundledCourses, _categoryFrontmatter, collaborators] = await Promise.all([
    _frontmatter.bundledCourses !== undefined
      ? getEntries(_frontmatter.bundledCourses)
      : Promise.resolve([]),
    getEntry(_frontmatter.category.collection, _frontmatter.category.id)!.then(
      (category) => category.data,
    ),
    _frontmatter.collaborators !== undefined
      ? await Promise.all(
          _frontmatter.collaborators.map(async (collaborator) => ({
            frontmatter: (await getEntry(
              collaborator.author.collection,
              collaborator.author.id,
            ))!.data,
            biography: collaborator.biography,
          })),
        )
      : [],
  ]),
  tags = await getEntries(_frontmatter.tags ?? []),
  { color: categoryColor, faqs: categoryFaqs } = _categoryFrontmatter,
  {
    benefits,
    description,
    faqs,
    features,
    hasGoal,
    hasSkills,
    heroImage,
    instructorEnabled,
    instructors: _instructors,
    isFree,
    isPreview,
    pricingPlanId,
    question,
    showMembership = true,
    technologies,
    thanks,
    title,
    videoId,
  } = _frontmatter,
  difficulty =
    _frontmatter.difficulty !== undefined
      ? await getEntry(
          _frontmatter.difficulty.collection!,
          _frontmatter.difficulty.id!,
        )
      : undefined,
  instructors = await getEntries(_instructors),
  isCourse = benefits !== undefined,
  isBundle = benefits === undefined,
  pricingPlan = await getTeachablePricingPlan(pricingPlanId);

const _personalMembership = await getEntry("memberships", "personal")!,
  _monthlyPackage = _personalMembership.data.packages[0],
  monthlyMembershipPlan = showMembership
    ? await getTeachablePricingPlan(_monthlyPackage.pricingPlanId)
    : null;

const fetchLessonCount = async (planId: number): Promise<number> => {
  try {
    const res = await fetch(`${site.workers.teachable}/curriculum/${planId}`);
    if (!res.ok) return 0;
    const sections: { lectures: unknown[] }[] = await res.json();
    return sections.reduce((sum, s) => sum + s.lectures.length, 0);
  } catch {
    return 0;
  }
};

const [_courseLessons, _bundledLessons] = await Promise.all([
  isCourse && !isPreview ? fetchLessonCount(pricingPlanId) : Promise.resolve(0),
  isBundle && !isPreview
    ? Promise.all(
        bundledCourses.map((c) => fetchLessonCount(c.data.pricingPlanId)),
      )
    : Promise.resolve([] as number[]),
]);
const heroTotalLessons = isCourse && !isPreview ? _courseLessons : undefined;
const bundleHours = isBundle
  ? bundledCourses
      .map(({ data: { benefits: b } }) => b?.hours ?? 0)
      .reduce((a, b) => a + b, 0)
  : undefined;
const bundleLessons =
  isBundle && !isPreview
    ? _bundledLessons.reduce((a, b) => a + b, 0)
    : undefined;

const difficultyLevelToEducationalLevel = (level: number) => {
  switch (level) {
    case 1:
      return "Beginner";
    case 2:
      return "Intermediate";
    default:
      return "Advanced";
  }
};

const _prerequisitess = await getCollection("prerequisites"),
  prerequisites = _prerequisitess.find(({ data: { nodes } }) =>
    nodes.find((node) => node.id === course.id),
  ),
  reactFlowNodes: ReactFlowNode[] | undefined =
    prerequisites !== undefined
      ? await Promise.all(
          prerequisites.data.nodes.map(async (node) => ({
            id: node.id,
            type: "linkNode",
            position: { x: 0, y: 0 },
            data: {
              difficulty: (
                await getEntry(node.collection, node.id)?.then(
                  async ({ data: { difficulty } }) =>
                    difficulty !== undefined
                      ? await getEntry(difficulty.collection, difficulty.id)
                      : undefined,
                )
              )?.data.id,
              isCurrent: node.id === course.id,
              label: (await getEntry(node.collection, node.id))!.data.title,
              href: `/courses/${node.id}`,
            },
          })),
        )
      : undefined,
  reactFlowEdges: ReactFlowEdge[] | undefined = prerequisites?.data.edges.map(
    (edge) => ({
      id: `${edge.from.id}TO${edge.to.id}`,
      source: edge.from.id,
      target: edge.to.id,
      // type: "smart",
      animated: Boolean(edge.optional),
    }),
  ),
  _companies = await getCollection("companies"),
  structuredData = JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Course",
    name: title,
    description,
    provider: {
      "@type": "Organization",
      name: site.name,
      url: Astro.site,
    },
    offers: [
      isFree
        ? {
            "@type": "Offer",
            category: "Free",
          }
        : {
            "@type": "Offer",
            category: "Paid",
            priceCurrency: pricingPlan?.currency,
            price: pricingPlan !== null ? pricingPlan.price / 100 : 0,
          },
    ],
    hasCourseInstance: [
      {
        "@type": "CourseInstance",
        courseMode: "Online",
        courseWorkload: `PT${Math.round(
          2 *
            (isBundle
              ? bundledCourses
                  .map(({ data: { benefits } }) => benefits?.hours ?? 0)
                  .reduce((b, a) => b + a, 0)
              : benefits!.hours),
        ).toFixed(0)}H`,
        instructor: instructors.map((instructor) => ({
          "@type": "Person",
          name: instructor.data.name,
          description:
            instructor.data.biography ??
            (instructor.data.company
              ? `${instructor.data.company.role} at ${_companies.find((_company) => _company.data.id === instructor.data.company!.entity.id)!.data.name}.`
              : ""),
          image: instructor.data.photo.src,
        })),
      },
    ],
    availableLanguage: ["en"],
    educationalLevel: difficultyLevelToEducationalLevel(
      difficulty?.data.level ??
        (
          await Promise.all(
            bundledCourses.map(async ({ data: { difficulty } }) =>
              difficulty !== undefined
                ? (await getEntry(difficulty.collection!, difficulty.id!))!.data
                    .level!
                : 1,
            ),
          )
        ).reduce((b, a) => (a > b ? a : b), 1),
    ),
    image: [heroImage.src],
    inLanguage: "en",
    publisher: {
      "@type": "Organization",
      name: site.name,
      url: Astro.site,
    },
  });

const _heroBg = await getImage({ src: heroImage, format: "webp", quality: "low", width: 1920 });
const heroImageBgSrc = _heroBg.src;
---

<BaseLayout
  {description}
  {title}
  image={{ alt: title, src: heroImage.src }}
  {structuredData}
  searchIndexable={true}
>
  {isCourse && <div data-pagefind-filter={`Difficulties: ${difficulty!}`} />}
  <div data-pagefind-filter="Categories:Courses (All)"></div>
  <div
    data-pagefind-filter={`Categories:${isBundle ? "Courses (Bundles)" : "Courses (Singles)"}`}
  >
  </div>
  {
    instructors.map((instructor) => (
      <div data-pagefind-filter={`Authors:${instructor.data.name}`} />
    ))
  }
  {
    collaborators.map((collaborator) => (
      <div data-pagefind-filter={`Authors:${collaborator.frontmatter.name}`} />
    ))
  }
  {tags.map((tag) => <div data-pagefind-filter={`Tags:${tag.id}`} />)}
  <article>
    <Hero
      {benefits}
      bundledCoursesCount={bundledCourses.length}
      {bundleHours}
      {bundleLessons}
      currency={pricingPlan?.currency}
      {description}
      {difficulty}
      {heroImage}
      {heroImageBgSrc}
      inRoadmap={prerequisites !== undefined}
      isFree={_frontmatter.isFree}
      {isBundle}
      {isPreview}
      {instructors}
      priceInCents={pricingPlan?.price}
      {pricingPlanId}
      {showMembership}
      monthlyMembershipPriceInCents={monthlyMembershipPlan?.price}
      monthlyMembershipPricingPlanId={_monthlyPackage.pricingPlanId}
      totalLessons={heroTotalLessons}
      {title}
      {videoId}
    >
      <div
        slot="roadmap"
        class="relative mx-auto w-full overflow-y-hidden overflow-x-visible"
      >
        <div class="z-10 mx-auto w-full overflow-hidden">
          <div id="app" class="w-full overflow-hidden">
            <Roadmap
              client:load
              initialNodes={reactFlowNodes}
              initialEdges={reactFlowEdges}
            />
          </div>
        </div>
      </div>
    </Hero>
    <CoursePageNav
      hasSkills={hasSkills}
      hasCourseDetails={hasGoal || !!question || !!features || !!technologies}
      {isBundle}
      {isCourse}
      {isPreview}
      hasPricing={!isPreview && pricingPlan !== null}
    />
    <slot name="description" />

    {/* 1. Skills — scannable checklist, first content after the nav */}
    {
      hasSkills && (
        <Skills color={categoryColor}>
          <slot name="skills" />
        </Skills>
      )
    }

    {/* 2. Collapsible details: Goal + Question + Features + Tech Stack */}
    {
      (hasGoal || !!question || !!features || !!technologies) && (
        <div id="course-details" class="scroll-mt-20">
          <details class="group">
            <summary class="cursor-pointer list-none select-none [&::-webkit-details-marker]:hidden">
              <div class="mx-auto max-w-5xl px-8 py-4">
                <div class="flex items-center justify-between gap-4 rounded-2xl bg-secondary/40 px-6 py-5 ring-1 ring-content/10 transition-colors hover:bg-secondary/60">
                  <div>
                    <p class="text-xs font-semibold uppercase tracking-widest text-content-1/50">Course Details</p>
                    <p class="mt-1 text-base font-bold text-content sm:text-lg">
                      {[hasGoal && "Goal", !!question && "Question", !!features && "How It Works", !!technologies && "Tech Stack"].filter(Boolean).join(" · ")}
                    </p>
                  </div>
                  <div class="flex shrink-0 items-center gap-2 rounded-full bg-cta px-5 py-2.5 text-sm font-semibold text-ctatext shadow-sm transition-colors hover:bg-accent-1">
                    <span class="group-open:hidden">Read More</span>
                    <span class="hidden group-open:inline">Close</span>
                    <svg
                      class="h-4 w-4 transition-transform duration-300 group-open:rotate-180"
                      viewBox="0 0 20 20"
                      fill="currentColor"
                      aria-hidden="true"
                    >
                      <path
                        fill-rule="evenodd"
                        d="M5.22 8.22a.75.75 0 0 1 1.06 0L10 11.94l3.72-3.72a.75.75 0 1 1 1.06 1.06l-4.25 4.25a.75.75 0 0 1-1.06 0L5.22 9.28a.75.75 0 0 1 0-1.06z"
                        clip-rule="evenodd"
                      />
                    </svg>
                  </div>
                </div>
              </div>
            </summary>
            {
              hasGoal && (
                <Goal color={categoryColor}>
                  <slot name="goal" />
                </Goal>
              )
            }
            {
              question && (
                <Question color={categoryColor} {question}>
                  <slot name="question" />
                </Question>
              )
            }
            {
              features && (
                <Features color={categoryColor} {features}>
                  <slot name="verticalSection" slot="verticalSection" />
                  <slot name="feature1" slot="feature1" />
                  <slot name="feature2" slot="feature2" />
                  <slot name="feature3" slot="feature3" />
                  <slot name="feature4" slot="feature4" />
                  <slot name="feature5" slot="feature5" />
                  <slot name="feature6" slot="feature6" />
                </Features>
              )
            }
            {technologies && <TechStack {technologies} color={categoryColor} />}
          </details>
        </div>
      )
    }

    {/* 3. Testimonials — parallax backdrop */}
    <div class="relative isolate overflow-hidden">
      <img
        src={heroImageBgSrc}
        alt=""
        aria-hidden="true"
        class="parallax-bg pointer-events-none absolute left-0 top-[-15%] h-[130%] w-full object-cover brightness-[0.25] [[data-theme=light]_&]:brightness-[0.4]"
        loading="lazy"
        decoding="async"
      />
      <div class="absolute inset-0 bg-bkg/80 [[data-theme=light]_&]:bg-bkg/90" aria-hidden="true" />
      <CourseTestimonials color={categoryColor} />
    </div>

    {/* 4. Curriculum / Bundled courses */}
    {
      isBundle ? (
        <BundledCourses color={categoryColor} {bundledCourses} />
      ) : (
        !isPreview && (
          <Curriculum
            color={categoryColor}
            courseId={course.id}
            {pricingPlanId}
          />
        )
      )
    }

    {/* 5. Instructor profile */}
    {
      instructorEnabled && (
        <Profile color={categoryColor} {collaborators} {thanks} />
      )
    }

    {/* 6. Pricing — parallax backdrop */}
    {
      isPreview ? null : pricingPlan !== null ? (
        <div class="relative isolate overflow-hidden">
          <img
            src={heroImageBgSrc}
            alt=""
            aria-hidden="true"
            class="parallax-bg pointer-events-none absolute left-0 top-[-15%] h-[130%] w-full object-cover brightness-[0.25] [[data-theme=light]_&]:brightness-[0.4]"
            loading="lazy"
            decoding="async"
          />
          <div class="absolute inset-0 bg-bkg/75 [[data-theme=light]_&]:bg-bkg/[0.88]" aria-hidden="true" />
          <Pricing
            {isCourse}
            {benefits}
            {bundledCourses}
            color={categoryColor}
            courseId={course.id}
            {pricingPlanId}
            priceInCents={pricingPlan.price}
            currency={pricingPlan.currency}
            {title}
            {showMembership}
          />
        </div>
      ) : (
        <p class="my-8 text-center text-2xl text-red-600">
          No pricing plan available. Check if TEACHABLE_API_KEY is missing.
        </p>
      )
    }

    {/* 7. FAQ */}
    <CourseFAQ
      {categoryFaqs}
      courseFaqs={faqs}
      color={categoryColor}
      {isBundle}
    />
  </article>
  {
    !isPreview && pricingPlan !== null && (
      <StickyCTA
        currency={pricingPlan!.currency}
        isFree={_frontmatter.isFree}
        priceInCents={pricingPlan!.price}
        {pricingPlanId}
        {showMembership}
        {title}
        client:load
      />
    )
  }
</BaseLayout>

<script>
  // Auto-expand collapsible details block on hash nav or nav link click
  const detailsEl = document.querySelector<HTMLDetailsElement>("#course-details details");
  if (detailsEl) {
    if (window.location.hash === "#course-details") {
      detailsEl.open = true;
    }
    document.querySelectorAll('a[href="#course-details"]').forEach((link) => {
      link.addEventListener("click", () => {
        detailsEl.open = true;
      });
    });
  }

  // Parallax: shift .parallax-bg images relative to their scroll position
  (function () {
    const imgs = document.querySelectorAll<HTMLImageElement>(".parallax-bg");
    if (!imgs.length) return;
    let ticking = false;
    function update() {
      for (const img of imgs) {
        const section = img.parentElement;
        if (!section) continue;
        const rect = section.getBoundingClientRect();
        const progress =
          (window.innerHeight - rect.top) / (window.innerHeight + rect.height);
        const clamped = Math.max(0, Math.min(1, progress));
        // Image overflows ±15% (top-[-15%] h-[130%]); shift within that range
        img.style.transform = `translateY(${(clamped - 0.5) * 30}%)`;
      }
      ticking = false;
    }
    window.addEventListener(
      "scroll",
      () => {
        if (!ticking) {
          requestAnimationFrame(update);
          ticking = true;
        }
      },
      { passive: true },
    );
    update();
  })();
</script>
<style is:global>
  #app {
    width: 100%;
    height: 60vh;
  }
  .react-flow__handle {
    opacity: 0;
  }
  .legend {
    display: flex;
    flex-wrap: wrap;
    gap: 1em;
    align-items: center;
    font-family: Arial, sans-serif;
  }

  .legend-item {
    display: flex;
    align-items: center;
  }

  .legend-color {
    width: 20px;
    height: 20px;
    display: inline-block;
    margin-right: 0.5em;
    border: 1px solid #333;
  }

  .legend-line {
    width: 40px;
    height: 0;
    border-top: 2px solid black;
    margin-right: 0.5em;
  }

  .dashed {
    border-top-style: dashed;
  }
</style>
