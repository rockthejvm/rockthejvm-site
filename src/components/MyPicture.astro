---
import type { ImageMetadata, ImageQuality } from "astro";
import { Picture } from "astro:assets";

interface Props {
  class?: string;
  alt: string;
  loading?: "lazy" | "eager";
  src: ImageMetadata;
  width?: number;
  height?: number;
  quality: ImageQuality;
  searchImage?: boolean;
  fetchpriority?: "high" | "low" | "auto";
  attrs?: Record<string, unknown>;
}

const {
    alt,
    class: additionalClasses,
    loading = "lazy",
    src,
    width,
    height,
    quality,
    searchImage = false,
    ...attrs
  } = Astro.props,
  // Generate AVIF + WebP only. Together these cover >97% of browsers
  // (caniuse). Skipping the original-format fallback (PNG/JPG) cuts ~33%
  // of generated image variants and ~30% of build-time image processing.
  // GIFs keep their original format because <Picture> can't animate AVIF/WebP
  // here without extra tooling.
  defaultFormats = src.format === "gif" ? [src.format] : ["avif", "webp"];
---

<Picture
  {alt}
  class:list={[additionalClasses]}
  formats={defaultFormats}
  fallbackFormat={src.format === "gif" ? "gif" : "webp"}
  {loading}
  {src}
  {width}
  {height}
  {quality}
  {...searchImage && { "data-pagefind-meta": "image[src], image_alt[alt]" }}
  {...attrs}
/>
