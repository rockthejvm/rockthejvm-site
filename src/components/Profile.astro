---
import MyPicture from "@/components/MyPicture.astro";
import Prose from "@/components/Prose.astro";
import site from "@/data/site.json";
import { type CollectionEntry, getEntry } from "astro:content";
import Section from "./Section.astro";

interface Props {
  color: CollectionEntry<"courseCategories">["data"]["color"];
  collaborators?: {
    frontmatter: CollectionEntry<"authors">["data"];
    biography: string;
  }[];
  thanks?: string;
}

const { color, collaborators, thanks } = Astro.props,
  author = await getEntry("authors", "daniel-ciocirlan")!;

const authorProfileBio =
  author.data.profileBio?.map((paragraph) =>
    paragraph
      .replace("{{studentsLabel}}", site.stats.studentsLabel)
      .replace("{{kidsLabel}}", site.stats.kidsLabel),
  ) ?? [author.data.biography].filter(Boolean);
---

<Section {color} title="Meet Rock the JVM">
  <div class="mx-auto flex max-w-5xl flex-col gap-8">
    <!-- Daniel's card -->
    <article class="card-shadow card-shadow-color overflow-hidden rounded-2xl bg-secondary ring-1 ring-content/10">
      <div class="flex flex-col items-center gap-4 border-b border-content/10 px-8 py-6 sm:flex-row sm:gap-6">
        <MyPicture
          src={author.data.photo}
          alt={author.data.name}
          class="h-20 w-20 shrink-0 rounded-full object-cover ring-2 ring-accent-1/30"
          quality="mid"
          width={80}
        />
        <div class="flex-1 text-center sm:text-left">
          <h3 class="text-lg font-bold text-content">{author.data.name}</h3>
          <p class="text-sm text-content-1">Founder, Rock the JVM</p>
        </div>
      </div>
      <div class="px-8 py-6">
        <Prose class="max-w-none text-sm leading-7 text-content-1 text-justify">
          {
            authorProfileBio.map((paragraph) => (
              <p>{paragraph}</p>
            ))
          }
        </Prose>
      </div>
    </article>

    <!-- Collaborator cards -->
    {
      collaborators?.map((collaborator) => (
        <article class="card-shadow card-shadow-color overflow-hidden rounded-2xl bg-secondary ring-1 ring-content/10">
          <div class="flex flex-col items-center gap-4 border-b border-content/10 px-8 py-6 sm:flex-row sm:gap-6">
            <MyPicture
              src={collaborator.frontmatter.photo}
              alt={collaborator.frontmatter.name}
              class="h-20 w-20 shrink-0 rounded-full object-cover ring-2 ring-accent-1/30"
              quality="mid"
              width={80}
            />
            <div class="flex-1 text-center sm:text-left">
              <p class="text-xs font-medium uppercase tracking-wide text-accent-2">In collaboration with</p>
              <h3 class="text-lg font-bold text-content">{collaborator.frontmatter.name}</h3>
            </div>
          </div>
          <div class="px-8 py-6">
            <Prose class="max-w-none text-sm leading-7 text-content-1 text-justify">
              <Fragment set:html={collaborator.biography} />
            </Prose>
          </div>
        </article>
      ))
    }

    <!-- Thanks -->
    {
      thanks && (
        <div class="rounded-2xl border border-content/10 bg-secondary/40 px-8 py-6">
          <h3 class="mb-3 text-base font-semibold text-content">With Special Thanks To</h3>
          <Prose class="text-sm leading-7 text-content-1">
            <Fragment set:html={thanks} />
          </Prose>
        </div>
      )
    }
  </div>
</Section>
