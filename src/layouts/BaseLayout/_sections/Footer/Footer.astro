---
import Facebook from "@/components/icons/Facebook.astro";
import GitHub from "@/components/icons/GitHub.astro";
import LinkedIn from "@/components/icons/LinkedIn.astro";
import RSS from "@/components/icons/RSS.astro";
import Twitter from "@/components/icons/Twitter.astro";
import YouTube from "@/components/icons/YouTube.astro";
import NewsletterSection from "@/components/NewsletterSection.astro";
import { getCollection } from "astro:content";
import FooterHelper from "./FooterHelper";

interface Props {
  hideNewsletter?: boolean;
  holiday?: boolean;
}

const { hideNewsletter = false, holiday } = Astro.props;

const allCategories = await getCollection("courseCategories");
const courseCategories = allCategories
  .filter((c) => c.id !== "bundle")
  .map((c) => ({ id: c.id, name: c.data.name }));
---

<FooterHelper client:visible {holiday} {courseCategories}>
  <Facebook slot="facebook" />
  <GitHub slot="github" />
  <LinkedIn slot="linkedin" />
  <Twitter slot="twitter" />
  <YouTube slot="youtube" />
  <RSS slot="rss" />
  {
    !holiday && !hideNewsletter && (
      <NewsletterSection
        stacked={true}
        title="Subscribe to our newsletter!"
        slot="newsletter"
      />
    )
  }
</FooterHelper>
